<?xml version="1.0" encoding="UTF-8"?>
<web-app>

<display-name>SWE 3 Mini App</display-name>

<listener>
  <listener-class>hbv.web.MyContextListener</listener-class>
</listener>

<filter> 
  <filter-name>myfilter</filter-name>
  <url-pattern>/filter</url-pattern>
  <filter-class>hbv.web.MyFilter</filter-class> 
  <async-supported>true</async-supported> 
</filter> 

<filter-mapping> 
  <filter-name>myfilter</filter-name>
  <url-pattern>/*</url-pattern> 
</filter-mapping> 

<servlet-mapping>
  <servlet-name>loginServlet</servlet-name>
  <url-pattern>/login</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>loginServlet</servlet-name>
  <servlet-class>hbv.web.LoginServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>logoutServlet</servlet-name>
  <url-pattern>/logout</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>logoutServlet</servlet-name>
  <servlet-class>hbv.web.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>insertServlet</servlet-name>
  <url-pattern>/insert</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>insertServlet</servlet-name>
  <servlet-class>hbv.web.InsertServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>selectServlet</servlet-name>
  <url-pattern>/select</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>selectServlet</servlet-name>
  <servlet-class>hbv.web.SelectServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>enqueueServlet</servlet-name>
  <url-pattern>/enqueue</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>enqueueServlet</servlet-name>
  <servlet-class>hbv.web.EnqueueServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>getbook</servlet-name>
  <url-pattern>/getbook</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>getbook</servlet-name>
  <servlet-class>hbv.web.GetBook</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>insertbook</servlet-name>
  <url-pattern>/insertbook</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>insertbook</servlet-name>
  <servlet-class>hbv.web.InsertBook</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>dbbook</servlet-name>
  <url-pattern>/dbbook</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>dbbook</servlet-name>
  <servlet-class>hbv.web.DbBook</servlet-class>
</servlet>

