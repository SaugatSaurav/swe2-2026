  <url-pattern>/catalog</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>catalogServlet</servlet-name>
  <servlet-class>hbv.web.CatalogServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>cartServlet</servlet-name>
  <url-pattern>/cart</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>cartServlet</servlet-name>
  <servlet-class>hbv.web.CartServlet</servlet-class>
</servlet>

<servlet-mapping>
  <servlet-name>mitarbeiterServlet</servlet-name>
  <url-pattern>/mitarbeiter</url-pattern>
</servlet-mapping>
<servlet>
  <servlet-name>mitarbeiterServlet</servlet-name>
  <servlet-class>hbv.web.MitarbeiterServlet</servlet-class>
</servlet>

</web-app>  
